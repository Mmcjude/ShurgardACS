@model LoginViewModel
@{ Layout = null; ViewData["Title"] = "Sign In"; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Sign In — Shurgard ACS</title>
    <link rel="stylesheet" href="~/css/site.css"/>
</head>
<body>
<div class="login-page">
    <div class="login-card">
        <div class="login-logo">
            <div class="brand">SHUR<span>GUARD</span></div>
            <div class="brand-sub">Access Control System</div>
        </div>
        <form asp-action="Login" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <div class="form-group">
                <label asp-for="Username">Username</label>
                <input asp-for="Username" class="form-control" placeholder="Enter username" autocomplete="username"/>
            </div>
            <div class="form-group">
                <label asp-for="Password">Password</label>
                <input asp-for="Password" class="form-control" type="password" placeholder="Enter password" autocomplete="current-password"/>
            </div>
            <div class="form-check">
                <input asp-for="RememberMe" type="checkbox" class="form-check-input" id="remember"/>
                <label for="remember" class="form-check-label">Remember me</label>
            </div>
            <button type="submit" class="btn btn-primary btn-full">Sign in</button>
        </form>
        <div class="demo-section">
            <div class="demo-title">Demo accounts</div>
            <table class="demo-table">
                <tr><td><span class="badge badge-admin">Admin</span></td><td>admin</td><td>Admin@123</td></tr>
                <tr><td><span class="badge badge-staff">Staff</span></td><td>jsmith</td><td>Staff@123</td></tr>
                <tr><td><span class="badge badge-viewer">Viewer</span></td><td>viewer1</td><td>View@123</td></tr>
                <tr><td><span class="badge badge-security">Security</span></td><td>guard1</td><td>Guard@123</td></tr>
            </table>
        </div>
    </div>
</div>
</body>
</html>
