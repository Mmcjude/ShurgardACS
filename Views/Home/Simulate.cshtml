@model SimulateViewModel
@{
    ViewData["Title"] = "Simulate Access"; ViewData["Nav"] = "simulate";
}

<div class="page-header">
    <h1 class="page-title">Simulate Access</h1>
    <p class="page-sub">Test whether a user can access a given access point.</p>
</div>

<div class="card" style="max-width:560px;">
    <form asp-action="Simulate" method="post">
        <div class="form-group">
            <label>User</label>
            <select name="SelectedUser" class="form-control">
                <option value="">— select user —</option>
                @foreach (var u in Model.Users)
                {
                    <option value="@u.Id" selected="@(Model.SelectedUser == u.Id.ToString())">
                        @u.FullName (@u.Role)
                    </option>
                }
            </select>
        </div>

        <div class="form-group">
            <label>Access Point</label>
            <select name="SelectedPoint" class="form-control">
                <option value="">— select access point —</option>
                @foreach (var ap in Model.AccessPoints)
                {
                    <option value="@ap.Id" selected="@(Model.SelectedPoint == ap.Id.ToString())">
                        @ap.Name — @ap.Location
                    </option>
                }
            </select>
        </div>

        <button type="submit" class="btn btn-primary">Check access</button>
    </form>

    @if (Model.Result.HasValue)
    {
        <div class="alert @(Model.Result.Value ? "alert-success" : "alert-danger")" style="margin-top:16px;">
            @(Model.Result.Value ? "✓" : "✗") @Model.ResultMessage
        </div>
    }
</div>