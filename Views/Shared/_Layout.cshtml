<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Shurgard ACS</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
@if (User.Identity?.IsAuthenticated == true)
{
<div class="app-shell">
    <div class="topbar">
        <div class="logo">SHUR<span>GUARD</span> &mdash; Access Control System</div>
        <div class="topbar-right">
            <span class="role-badge role-@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value">
                @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
            </span>
            <span class="user-name">@User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value</span>
            <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline;">
                <button type="submit" class="btn btn-sm btn-ghost">Sign out</button>
            </form>
        </div>
    </div>
    <div class="layout">
        <nav class="sidebar">
            <div class="sidebar-user">
                <div class="sidebar-name">@User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value</div>
                <div class="sidebar-username">@User.Identity.Name</div>
            </div>
            <div class="sidebar-section">Navigation</div>
            <a class="nav-item @(ViewData["Nav"]?.ToString() == "dashboard" ? "active" : "")" asp-controller="Home" asp-action="Index">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="1" y="1" width="6" height="6" rx="1" fill="currentColor" opacity=".7"/><rect x="9" y="1" width="6" height="6" rx="1" fill="currentColor" opacity=".7"/><rect x="1" y="9" width="6" height="6" rx="1" fill="currentColor" opacity=".7"/><rect x="9" y="9" width="6" height="6" rx="1" fill="currentColor" opacity=".4"/></svg>
                Dashboard
            </a>
            <a class="nav-item @(ViewData["Nav"]?.ToString() == "access" ? "active" : "")" asp-controller="Home" asp-action="AccessPoints">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="2" y="6" width="12" height="9" rx="1.5" stroke="currentColor" stroke-width="1.2"/><path d="M5 6V4.5a3 3 0 0 1 6 0V6" stroke="currentColor" stroke-width="1.2"/><circle cx="8" cy="10.5" r="1.2" fill="currentColor"/></svg>
                Access Points
            </a>
            <a class="nav-item @(ViewData["Nav"]?.ToString() == "logs" ? "active" : "")" asp-controller="Home" asp-action="Logs">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 4h10M3 8h10M3 12h6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
                Activity Log
            </a>
            <a class="nav-item @(ViewData["Nav"]?.ToString() == "simulate" ? "active" : "")" asp-controller="Home" asp-action="Simulate">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.2"/><path d="M6 8l2-2 2 2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/><path d="M8 6v4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
                Simulate Access
            </a>
            @if (User.IsInRole("SystemAdmin"))
            {
            <div class="sidebar-section">Admin</div>
            <a class="nav-item @(ViewData["Nav"]?.ToString() == "users" ? "active" : "")" asp-controller="Users" asp-action="Index">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="6" cy="5" r="2.5" stroke="currentColor" stroke-width="1.2"/><path d="M1 13c0-2.76 2.24-5 5-5h.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><circle cx="12" cy="11" r="3" stroke="currentColor" stroke-width="1.2"/></svg>
                Manage Users
            </a>
            <a class="nav-item" asp-controller="Home" asp-action="ExportLogs">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 12h10M8 3v7m-3-3 3 3 3-3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Export CSV
            </a>
            }
        </nav>
        <main class="main-content">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }
            @RenderBody()
        </main>
    </div>
</div>
}
else
{
    @RenderBody()
}
</body>
</html>
